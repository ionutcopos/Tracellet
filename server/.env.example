# Optional. Without it, the app uses a template summary instead of AI narration.
# Free key: https://console.groq.com
GROQ_API_KEY=

# Live Solana data (transfers + holdings). Free tier: https://helius.dev
HELIUS_API_KEY=

# Live EVM data (Ethereum/Base/Arbitrum/Polygon/BSC). Etherscan V2 unified API —
# one key works across all EVM chains. Free: https://etherscan.io/apis
ETHERSCAN_API_KEY=
